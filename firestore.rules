rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tgfhiyfvhtfghug@gmail.com' ||
        request.auth.uid == 'EfPgDIlb8cVAxG2Zj7iCe1ZtzqB3'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function profileExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    // --- Core Rules ---

    match /gyms/{gymId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
      allow update: if isSignedIn() && profileExists(request.auth.uid) && getProfile(request.auth.uid).role == 'owner' && getProfile(request.auth.uid).gymId == gymId;
    }

    match /users/{userId} {
      allow read, write: if isSuperAdmin() || isOwner(userId);
      // Allow owners of the same gym to see and manage members
      allow read, write: if isSignedIn() && 
                    profileExists(request.auth.uid) && 
                    getProfile(request.auth.uid).role == 'owner' && 
                    (resource == null ? request.resource.data.gymId == getProfile(request.auth.uid).gymId : resource.data.gymId == getProfile(request.auth.uid).gymId);
    }

    match /attendance/{atId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() || 
        resource.data.userId == request.auth.uid || 
        (profileExists(request.auth.uid) && getProfile(request.auth.uid).gymId == resource.data.gymId)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /equipment/{eqId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (
        isSignedIn() && 
        profileExists(request.auth.uid) && 
        getProfile(request.auth.uid).role == 'owner' && 
        getProfile(request.auth.uid).gymId == (resource != null ? resource.data.gymId : request.resource.data.gymId)
      );
    }

    match /payments/{payId} {
      allow read, update: if isSuperAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || 
        (profileExists(request.auth.uid) && getProfile(request.auth.uid).role == 'owner' && getProfile(request.auth.uid).gymId == resource.data.gymId)));
      allow create: if isSuperAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (
        isSignedIn() && 
        profileExists(request.auth.uid) && 
        getProfile(request.auth.uid).role == 'owner' && 
        getProfile(request.auth.uid).gymId == (resource != null ? resource.data.gymId : request.resource.data.gymId)
      );
    }

    match /challenges/{chId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /challengeParticipants/{pId} {
      // Leaderboard access: Everyone in the gym can see participant names/progress
      allow read: if isSignedIn() && (
        isSuperAdmin() || 
        resource.data.userId == request.auth.uid || 
        (profileExists(request.auth.uid) && getProfile(request.auth.uid).gymId == resource.data.gymId)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    match /personalRecords/{prId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    match /notifications/{nId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn();
    }

    match /live_alerts/{alertId} {
      allow read, update: if isSuperAdmin() || (
        isSignedIn() && 
        profileExists(request.auth.uid) && 
        getProfile(request.auth.uid).role == 'owner' && 
        getProfile(request.auth.uid).gymId == resource.data.gymId
      );
      allow create: if isSignedIn();
    }

    match /workoutPlans/{plId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /dietPlans/{plId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /membershipTiers/{tId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && profileExists(request.auth.uid) && getProfile(request.auth.uid).role == 'owner' && getProfile(request.auth.uid).gymId == (resource == null ? request.resource.data.gymId : resource.data.gymId));
    }

    // --- Gamification ---
    match /memberGamification/{userId} {
      allow read: if isSignedIn(); // Allow leaderboard reading
      allow write: if isSuperAdmin() || isOwner(userId);
    }

    match /userBadges/{badgeId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /equipmentUsage/{usageId} {
      allow read: if isSuperAdmin() || (
        isSignedIn() && 
        profileExists(request.auth.uid) && 
        getProfile(request.auth.uid).role == 'owner'
      );
      allow create: if isSignedIn();
    }

    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
